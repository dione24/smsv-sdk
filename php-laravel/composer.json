{
  "name": "sahelpay/smsv-laravel",
  "description": "Official SMSV SDK for Laravel 12+ (WhatsApp campaigns, senders, contacts, templates, webhooks).",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "guzzlehttp/guzzle": "^7.8",
    "illuminate/support": "^12.0",
    "psr/http-message": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "SahelPay\\Smsv\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "SahelPay\\Smsv\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^11.1"
  },
  "extra": {
    "laravel": {
      "providers": [
        "SahelPay\\Smsv\\SmsvServiceProvider"
      ],
      "aliases": {
        "SMSV": "SahelPay\\Smsv\\Smsv"
      }
    }
  },
  "scripts": {
    "test": "phpunit"
  }
}
